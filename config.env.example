# zgate-tunnel-sdk-c-builder configuration
# Copyright (c) eCloudseal Inc.  All rights reserved.  Author: Lai Hou Chang (James Lai)
# Copy to config.env and adjust as needed.

export VCPKG_ROOT="${VCPKG_ROOT:-/home/user/vcpkg}"
export WORK_DIR="${WORK_DIR:-$(cd "$(dirname "$0")" && pwd)/work}"
export OUTPUT_DIR="${OUTPUT_DIR:-$(cd "$(dirname "$0")" && pwd)/output}"

# zgate-sdk-c 來源：使用 zgate-sdk-c-builder 的產出目錄（請先執行該專案 build.sh）
export ZGATE_SDK_BUILDER_OUTPUT="${ZGATE_SDK_BUILDER_OUTPUT:-/home/user/zgate-sdk-c-builder/output}"

# Optional: pin tunnel version
# export ZITI_TUNNEL_SDK_TAG="v1.10.10"

# Optional: presets to build (semicolon-separated; default: 7 平台，Windows x86_64 用 MinGW)
# export TUNNEL_PRESETS="ci-linux-x64;ci-linux-arm64;ci-linux-arm;ci-macOS-x64;ci-macOS-arm64;ci-windows-x64-mingw;ci-windows-arm64-mingw"
# Optional: skip cross toolchain install (Darwin/Windows)
# export SKIP_CROSS_TOOLCHAINS=1
